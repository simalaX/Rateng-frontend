# Copy this file to .env for local development.
# On Render, set these in the dashboard / render.yaml instead — see README.md.

# URL of the deployed backend API (no trailing slash).
# Local example:
REACT_APP_API_URL=http://localhost:8000

# Optional — Google rating badge shown on the site. Defaults to demo
# values if not set; update once your Google Business Profile is live.
REACT_APP_GOOGLE_RATING=4.9
REACT_APP_GOOGLE_REVIEW_COUNT=50+

# Optional — used for the Google Maps embed on the Contact page.
# Update with your exact business address once confirmed.
REACT_APP_MAP_QUERY=Nairobi, Kenya
